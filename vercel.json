{
    "version": 2,
    "buildCommand": "bun run build",
    "env": {
        "GEMINI_API_KEY": "@gemini_api_key"
    },
    "builds": [
        {
            "src": "api/index.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": "dist/public/**"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.ts"
        }
    ]
}